# Copy to functions/.env for emulators (never commit real keys).
# In production these are Cloud secrets: firebase functions:secrets:set DEEPSEEK_API_KEY  (etc.)
DEEPSEEK_API_KEY=__DEEPSEEK_API_KEY__
TAVILY_API_KEY=__TAVILY_API_KEY__
DEEPSEEK_MODEL=deepseek-v4-pro
# xAI Grok — powers the multilingual /translate route (EN -> Simplified Chinese + Pinyin)
XAI_API_KEY=__XAI_API_KEY__
XAI_MODEL=grok-4.3
# GitHub fine-grained PAT (Contents+Metadata read) — server-side only, powers the commit tracker.
GITHUB_TOKEN=__GITHUB_TOKEN__
GITHUB_USER=Aroxora

# For local admin testing of callables only (real auth comes from frontend Firebase Auth)
# No service account needed for emulators when using the Admin SDK in functions (ADC or GOOGLE_APPLICATION_CREDENTIALS)
