# Copy to studio/.env (gitignored). NEVER commit real keys.
DEEPSEEK_API_KEY=__DEEPSEEK_API_KEY__
DEEPSEEK_MODEL=deepseek-v4-pro
# xAI Grok image model (the "best AI video for long form" = stitched descriptive images)
XAI_API_KEY=__XAI_API_KEY__
XAI_IMAGE_MODEL=grok-imagine-image

# Firebase (writes videos/{id} + uploads the mp4/thumb to Storage)
FIREBASE_PROJECT_ID=twitch-womens-history
FIREBASE_STORAGE_BUCKET=twitch-womens-history.firebasestorage.app
GOOGLE_APPLICATION_CREDENTIALS=../outreach/service-account.json

# Optional: override macOS `say` with a cloud TTS that reads stdin text and writes mp3 to stdout.
# TTS_CMD=
