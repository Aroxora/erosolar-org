# Optional local env for lambda/deploy.sh (gitignored as .env). The deploy script
# also reads DEEPSEEK_API_KEY / TAVILY_API_KEY from ../functions/.env if unset.
DEEPSEEK_API_KEY=__DEEPSEEK_API_KEY__
TAVILY_API_KEY=__TAVILY_API_KEY__
DEEPSEEK_MODEL=deepseek-v4-pro
# xAI Grok — powers the public /translate route (multilingual EN/中文/拼音)
XAI_API_KEY=__XAI_API_KEY__
XAI_MODEL=grok-4.3
# GitHub fine-grained PAT — powers the public /commits proxy (rate-limit-proof, public repos).
GITHUB_TOKEN=__GITHUB_TOKEN__
GITHUB_USER=Aroxora

# Origin allowed by the Function URL CORS (your live site).
ALLOW_ORIGIN=https://erosolar.org
FIREBASE_PROJECT_ID=twitch-womens-history

# OPTIONAL — only to also deploy the daily scheduled scanner (writes Firestore
# itself). Download from Firebase console → Project settings → Service accounts →
# Generate new private key, then paste the JSON (one line) or its base64 here.
# FIREBASE_SERVICE_ACCOUNT=
