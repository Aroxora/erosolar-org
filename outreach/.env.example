# Copy to outreach/.env (gitignored) and fill in real values. NEVER commit real secrets.
# Proton Bridge runs locally on 127.0.0.1, so this worker must run on the machine
# where Proton Bridge is running (the cloud cannot reach localhost).
IMAP_HOST=127.0.0.1
IMAP_PORT=1143
IMAP_USER=erolunar@pm.me
IMAP_PASS=__PROTON_BRIDGE_PASSWORD__
IMAP_TLS=STARTTLS

SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=erolunar@pm.me
SMTP_PASS=__PROTON_BRIDGE_PASSWORD__
SMTP_SECURE=false   # false => STARTTLS style for bridge submission port; true for 465 implicit

# DeepSeek + Tavily (for on-demand draft enhancement)
DEEPSEEK_API_KEY=__DEEPSEEK_API_KEY__
TAVILY_API_KEY=__TAVILY_API_KEY__

# GitHub PAT — commit-momentum alerter + Dependabot auto-merge (Contents+PRs write for merge)
GITHUB_TOKEN=__GITHUB_TOKEN__
GITHUB_USER=Aroxora

# Gmail — read + track every email across one or more accounts (app-specific passwords).
# Preferred: a JSON array (one line). Leave blank to skip Gmail.
GMAIL_ACCOUNTS=[{"user":"__GMAIL_1__","pass":"__APP_PW_1__"},{"user":"__GMAIL_2__","pass":"__APP_PW_2__"}]
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
# (Single-account fallback if GMAIL_ACCOUNTS is unset: GMAIL_USER=... GMAIL_APP_PASSWORD=...)

# Firebase
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# or SERVICE_ACCOUNT=./service-account.json (for the worker script)

# Poll interval ms (default ~3min)
POLL_MS=180000

# Set true to never actually send
DRY_RUN=false
