rules_version = '2';

// erosolar-org — Bo Shang central portfolio + agentic control surface.
// Public content (jobs, phd status, blog/updates, resume highlights) is world-readable.
// All mutating writes are performed exclusively by:
//   - Cloud Functions using Admin SDK (bypass rules), or
//   - Local/Lambda workers using service account.
// Client writes are denied except for narrowly-scoped owner self-management (future).
// Admin-only surfaces (chatbot updates, outreach control, history) require
// Firebase Auth + exact email match on the callable side (enforced in code).
service cloud.firestore {
  match /databases/{database}/documents {

    // === PUBLIC LIVE DATA (agent-written, world-readable) ===
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if false;
    }
    match /phdPrograms/{programId} {
      allow read: if true;
      allow write: if false;
    }
    match /updates/{updateId} {   // blog-style dated agentic posts (resume, jobs, phd, site changes)
      allow read: if true;
      allow write: if false;
    }
    match /outreachHistory/{entryId} {
      // History is readable by the single admin (checked in callable / rules below via token)
      // but for client we gate strictly; public never sees full history.
      allow read: if request.auth != null && request.auth.token.email == 'daburu.dragon@gmail.com';
      allow write: if false;
    }

    // Job applications (auto + manual) — full text + status, admin-only read, server writes.
    match /jobApplications/{appId} {
      allow read: if request.auth != null && request.auth.token.email == 'daburu.dragon@gmail.com';
      allow write: if false;
    }

    // === ADMIN CONTROL SURFACE (owner only via auth) ===
    match /settings/{doc} {
      allow read: if request.auth != null && request.auth.token.email == 'daburu.dragon@gmail.com';
      allow write: if false;  // writes only via admin callables or functions
    }

    // Chat log for the admin chatbot (history of prompts/responses + actions taken)
    match /chatLogs/{logId} {
      allow read: if request.auth != null && request.auth.token.email == 'daburu.dragon@gmail.com';
      allow write: if false;
    }

    // Temporary queues (drained by trusted local worker / functions)
    match /applicationQueue/{qid} {
      allow read: if request.auth != null && request.auth.token.email == 'daburu.dragon@gmail.com';
      allow write: if false;
    }
    match /outreachQueue/{qid} {
      allow read: if request.auth != null && request.auth.token.email == 'daburu.dragon@gmail.com';
      allow write: if false;
    }

    // === OWNER SELF DATA (future expansion, e.g. personal bookmarks) ===
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Deny by default for anything not explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
