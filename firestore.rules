rules_version = '2';

// erosolar-org — Firestore security rules (Firebase Spark plan; no Cloud Functions).
//
// Public content (jobs, phd status, dated updates) is world-readable.
// The single admin (daburu.dragon@gmail.com, via Google sign-in) writes the
// agentic results + controls DIRECTLY from the browser — the AWS Lambda backend
// only computes (DeepSeek + Tavily) and never touches Firestore, so no
// service-account key is needed for the interactive path.
//
// The local Proton-Bridge worker (and the optional scheduled Lambda scanner) use
// the Admin SDK with a service-account key, which BYPASSES these rules entirely.
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'daburu.dragon@gmail.com'
        && request.auth.token.email_verified == true;
    }

    // ── public live data: world-readable; admin writes results from the browser ──
    match /jobs/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /phdPrograms/{id}  { allow read: if true; allow write: if isAdmin(); }
    match /updates/{id}      { allow read: if true; allow write: if isAdmin(); }

    // ── admin control surface (owner only) ──
    match /settings/{doc}            { allow read, write: if isAdmin(); }
    match /chatLogs/{id}             { allow read, write: if isAdmin(); }
    match /outreachQueue/{id}        { allow read, write: if isAdmin(); }
    match /applicationQueue/{id}     { allow read, write: if isAdmin(); }

    // ── written only by the trusted local worker / scheduled scanner via Admin SDK
    //    (bypasses rules); the admin can read the full history in the browser ──
    match /jobApplications/{id}      { allow read: if isAdmin(); allow write: if false; }
    match /outreachHistory/{id}      { allow read: if isAdmin(); allow write: if false; }

    // ── optional per-user self data (future) ──
    match /users/{uid}/{document=**} { allow read, write: if request.auth != null && request.auth.uid == uid; }

    // deny everything else
    match /{document=**} { allow read, write: if false; }
  }
}
